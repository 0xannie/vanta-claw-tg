{
  "name": "@layerzerolabs/lz-serdes",
  "version": "3.0.137",
  "description": "LayerZero Core Library",
  "license": "BUSL-1.1",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "$npm_execpath clean-prebuild && $npm_execpath build-ts",
    "build-ts": "$npm_execpath tsc --noEmit && $npm_execpath tsup",
    "clean": "$npm_execpath clean-prebuild && rm -rf .turbo",
    "clean-prebuild": "rm -rf dist",
    "test": "$npm_execpath jest"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@layerzerolabs/lz-core": "^3.0.137",
    "@layerzerolabs/lz-utilities": "^3.0.137",
    "@layerzerolabs/tron-utilities": "^3.0.137",
    "aptos": "^1.20.0",
    "bip39": "^3.1.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^5.8.0",
    "memoizee": "^0.4.17",
    "tronweb": "^5.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@layerzerolabs/tronweb-typescript": "^0.0.0",
    "@layerzerolabs/tsup-config-next": "^3.0.137",
    "@layerzerolabs/typescript-config-next": "^3.0.137",
    "@types/jest": "^29.5.10",
    "@types/tronweb": "npm:@layerzerolabs/tronweb-typescript@workspace:^",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsup": "^8.3.5",
    "typescript": "~5.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}