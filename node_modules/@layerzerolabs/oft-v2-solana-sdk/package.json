{
  "name": "@layerzerolabs/oft-v2-solana-sdk",
  "version": "3.0.137",
  "license": "BUSL-1.1",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json",
    "./deployments/*": "./deployments/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "deployments/**/*",
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "api-gen": "$npm_execpath ts-node scripts/generate.ts",
    "build": "$npm_execpath clean-prebuild && $npm_execpath sync && $npm_execpath api-gen && $npm_execpath build-ts",
    "build-ts": "$npm_execpath tsc --noEmit && $npm_execpath tsup",
    "clean": "$npm_execpath clean-prebuild",
    "clean-prebuild": "rm -rf .turbo target dist",
    "sync": "./sync.mjs",
    "test": "yarn run ts-mocha -b -p ./tsconfig.json -t 10000000 tests/**/entry.test.ts",
    "test-extend": "yarn run ts-mocha -b -p ./tsconfig.json -t 10000000 tests/extend_account.test.ts"
  },
  "dependencies": {
    "@ethersproject/bytes": "^5.8.0",
    "@layerzerolabs/lz-foundation": "^3.0.137",
    "@layerzerolabs/lz-solana-sdk-v2": "^3.0.137",
    "@layerzerolabs/lz-v2-utilities": "^3.0.137",
    "@metaplex-foundation/beet": "^0.7.1",
    "@metaplex-foundation/beet-solana": "^0.4.0",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-eddsa-web3js": "^0.9.2",
    "@metaplex-foundation/umi-program-repository": "^0.9.2",
    "@metaplex-foundation/umi-web3js-adapters": "^0.9.2",
    "@solana/web3.js": "1.95.8",
    "bn.js": "^5.2.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@kinobi-so/nodes": "^0.21.4",
    "@kinobi-so/nodes-from-anchor": "^0.21.2",
    "@kinobi-so/renderers": "^0.21.3",
    "@kinobi-so/renderers-js-umi": "^0.21.6",
    "@layerzerolabs/lz-definitions": "^3.0.137",
    "@layerzerolabs/oft-v2-solana": "^0.0.0",
    "@layerzerolabs/tsup-config-next": "^3.0.137",
    "@layerzerolabs/typescript-config-next": "^3.0.137",
    "@metaplex-foundation/mpl-toolbox": "^0.9.2",
    "@metaplex-foundation/solita": "^0.20.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@noble/secp256k1": "^1.7.1",
    "@solana/spl-token": "^0.3.9",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/chai-as-promised": "^7.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.5",
    "axios": "^1.6.2",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "kinobi": "^0.21.4",
    "mocha": "^10.2.0",
    "rimraf": "^5.0.5",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "tsup": "^8.3.5",
    "typescript": "~5.2.2",
    "zx": "^8.1.3"
  },
  "publishConfig": {
    "access": "public"
  }
}