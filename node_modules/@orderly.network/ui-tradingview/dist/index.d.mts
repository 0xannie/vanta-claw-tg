     */
    le(n1: number, n2: number): number;
    /**
     * Checks if `n1` is equal to `n2`.
     *
     * @param n1
     * @param n2
     * @returns `1` if `n1` is equal to `n2`, `0` otherwise.
     */
    eq(n1: number, n2: number): number;
    /**
     * Checks if `n1` is not equal to `n2`.
